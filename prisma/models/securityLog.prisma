model SecurityLog {
    id String @id @default(uuid())

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    sessionId String?
    
    event     SecurityEvent
    ipAddress String?
    userAgent String?

    // Detailed JSON for forensics
    metadata Json?

    // Risk scoring (e.g., 0.0 to 1.0)
    riskScore Float @default(0.0)

    createdAt DateTime @default(now())

    @@map("security_logs")
}

enum SecurityEvent {
    LOGIN_SUCCESS
    LOGIN_FAILURE
    REFRESH_SUCCESS
    REFRESH_REUSE_DETECTED
    PASSWORD_CHANGE_SUCCESS
    PASSWORD_RESET_REQUEST
    PASSWORD_RESET_SUCCESS
    MFA_ENABLED
    MFA_DISABLED
    MFA_VERIFY_SUCCESS
    MFA_VERIFY_FAILURE
    ACCOUNT_SUSPENDED
    ACCOUNT_DELETED
}
