model UserRole {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    role Role

    grantedById String?
    grantedBy   Admin?  @relation(fields: [grantedById], references: [id])

    description  String?
    
    grantedAt DateTime  @default(now())
    revokedAt DateTime?

    @@unique([userId, role])
    @@map("user_roles")
}
