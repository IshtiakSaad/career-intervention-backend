model Document {
    id String @id @default(uuid())

    ownerId String
    owner   User   @relation(fields: [ownerId], references: [id])

    applicationId String?
    application   MentorApplication? @relation(fields: [applicationId], references: [id])

    type               DocumentType
    storageUrl         String
    verificationStatus DocumentStatus @default(PENDING)

    verifiedById String?
    verifiedBy   Admin?  @relation(fields: [verifiedById], references: [id])

    description String?

    verifiedAt DateTime?
    createdAt  DateTime  @default(now())

    @@map("documents")
}
