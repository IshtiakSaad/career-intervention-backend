NODE_ENV=development
PORT=5000
DATABASE_URL="postgresql://user:pass@127.0.0.1:5432/db?schema=public"
DB_URL="postgresql://user:pass@127.0.0.1:5432/db?schema=public"

BCRYPT_SALT_ROUNDS=12
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# AES-256 Encryption Keys for CipherService (32-byte hex)
ENCRYPTION_KEY_V1=your_32_byte_hex_key_here
CURRENT_KEY_ID=v1

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=admin_password_here

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OPENROUTER_API_KEY=

# SSLCommerz Configuration (Sandbox)
SSL_STORE_ID=
SSL_STORE_PASSWORD=
SSL_IS_SANDBOX=true
SSL_BASE_URL=https://sandbox.sslcommerz.com
